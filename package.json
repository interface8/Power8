    "next": "14.2.35",
    "pg": "^8.18.0",
    "prisma": "^7.4.0",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
